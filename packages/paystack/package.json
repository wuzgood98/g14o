{
  "name": "@g14o/paystack",
  "version": "0.1.0",
  "description": "Paystack billing plugin for Better Auth — subscriptions, checkout, webhooks, and customer management.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/paystack"
  },
  "author": "Gideon Ofori Addo",
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o/tree/main/packages/paystack#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "better-auth": ">=1.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "@better-auth/core": "1.6.16",
    "@types/node": "^25.9.3",
    "@workspace/typescript-config": "workspace:*",
    "better-auth": "^1.6.16",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./client": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js"
      }
    }
  },
  "keywords": [
    "paystack",
    "better-auth",
    "billing",
    "subscriptions",
    "payments",
    "webhooks",
    "typescript"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
