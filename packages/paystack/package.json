{
  "name": "@g14o/paystack",
  "version": "0.1.1",
  "description": "Typed Paystack REST SDK with retries, Zod-validated responses, and webhook verification.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/paystack"
  },
  "author": "Gideon Ofori Addo",
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o/tree/main/packages/paystack#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@workspace/typescript-config": "workspace:*",
    "dotenv": "^16.6.1",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "paystack",
    "billing",
    "subscriptions",
    "payments",
    "webhooks",
    "typescript"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
