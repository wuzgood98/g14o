{
  "name": "@g14o/utils",
  "version": "0.5.0",
  "description": "Deprecated shim — use @g14o/core instead.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-shim.mjs --cwd packages/utils utils:@g14o/core types:@g14o/core/types config:@g14o/core/config",
    "clean": "rimraf dist",
    "prepack": "node ../../scripts/build-shim.mjs --cwd packages/utils utils:@g14o/core types:@g14o/core/types config:@g14o/core/config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@g14o/core": "workspace:^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/typescript-config": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5"
  },
  "exports": {
    ".": "./src/utils.ts",
    "./types": "./src/types.ts",
    "./config": "./src/config.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/utils.d.ts",
        "import": "./dist/utils.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      }
    }
  },
  "keywords": [
    "nextjs",
    "utils",
    "fetch"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
