{
  "extends": "@workspace/typescript-config/library-build.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@g14o/core": ["./src/utils.ts"],
      "@g14o/core/types": ["./src/types.ts"],
      "@g14o/core/config": ["./src/config.ts"],
      "@g14o/core/cache": ["./src/cache/index.ts"],
      "@g14o/core/ratelimit": ["./src/ratelimit/index.ts"]
    },
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.integration.test.ts"
  ]
}
