{
  "name": "@g14o/utils",
  "version": "0.2.0",
  "description": "Shared utilities for Next.js apps: fetch helpers, formatting, and shared types.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/typescript-config": "workspace:*",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": "./src/utils.ts",
    "./types": "./src/types.ts",
    "./config": "./src/config.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/utils.d.ts",
        "import": "./dist/utils.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      }
    }
  },
  "keywords": [
    "nextjs",
    "utils",
    "fetch"
  ],
  "engines": {
    "node": ">=20"
  }
}
