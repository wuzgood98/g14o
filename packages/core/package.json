{
  "name": "@g14o/core",
  "version": "1.1.0",
  "description": "Core utilities, cache, and rate limiting for Next.js apps.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o/tree/main/packages/core#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "peerDependencies": {
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.0",
    "next": ">=15"
  },
  "peerDependenciesMeta": {
    "@upstash/ratelimit": {
      "optional": true
    },
    "@upstash/redis": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.0",
    "@workspace/typescript-config": "workspace:*",
    "dotenv": "^16.6.1",
    "next": "16.2.6",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": "./src/utils.ts",
    "./types": "./src/types.ts",
    "./config": "./src/config.ts",
    "./cache": "./src/cache/index.ts",
    "./ratelimit": "./src/ratelimit/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/utils.d.ts",
        "import": "./dist/utils.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      },
      "./cache": {
        "types": "./dist/cache/index.d.ts",
        "import": "./dist/cache/index.js"
      },
      "./ratelimit": {
        "types": "./dist/ratelimit/index.d.ts",
        "import": "./dist/ratelimit/index.js"
      }
    }
  },
  "keywords": [
    "nextjs",
    "utils",
    "cache",
    "rate-limit",
    "fetch"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
