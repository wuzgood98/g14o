{
  "name": "@g14o/core",
  "version": "1.2.0",
  "description": "Core utilities and shared types for Next.js apps.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o/tree/main/packages/core",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@upstash/redis": "^1.34.0"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@upstash/redis": "^1.34.0",
    "@workspace/typescript-config": "workspace:*",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": "./src/utils.ts",
    "./types": "./src/types.ts",
    "./config": "./src/config.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/utils.d.ts",
        "import": "./dist/utils.js"
      },
      "./types": {
        "types": "./dist/types.d.ts",
        "import": "./dist/types.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      }
    }
  },
  "keywords": [
    "nextjs",
    "utils",
    "fetch"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
