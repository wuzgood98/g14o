{
  "extends": "@workspace/typescript-config/library-build.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strictNullChecks": true,
    "isolatedDeclarations": false,
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.d.ts",
    "src/**/*.d.ts.map",
    "src/**/*.js",
    "src/**/*.test.ts",
    "src/**/*.integration.test.ts"
  ]
}
