{
  "name": "@g14o/paystack-better-auth",
  "version": "0.1.0",
  "description": "Paystack billing plugin for Better Auth — subscriptions, checkout, webhooks, and customer management.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/paystack-better-auth"
  },
  "author": "Gideon Ofori Addo",
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o/tree/main/packages/paystack-better-auth#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@g14o/paystack": "^0.1.0",
    "better-auth": ">=1.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "devDependencies": {
    "@better-auth/core": "1.6.16",
    "@g14o/paystack": "workspace:*",
    "@types/node": "^25.9.3",
    "@workspace/typescript-config": "workspace:*",
    "better-auth": "^1.6.16",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "paystack",
    "better-auth",
    "billing",
    "subscriptions",
    "payments",
    "webhooks",
    "typescript"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
