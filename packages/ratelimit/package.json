{
  "name": "@g14o/ratelimit",
  "version": "0.5.0",
  "description": "Deprecated shim — use @g14o/core/ratelimit instead.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../scripts/build-shim.mjs --cwd packages/ratelimit index:@g14o/core/ratelimit",
    "clean": "rimraf dist",
    "prepack": "node ../../scripts/build-shim.mjs --cwd packages/ratelimit index:@g14o/core/ratelimit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@g14o/core": "workspace:^1.2.0"
  },
  "peerDependencies": {
    "next": ">=15"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@workspace/typescript-config": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "nextjs",
    "rate-limit",
    "upstash",
    "redis"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
