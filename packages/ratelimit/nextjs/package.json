{
  "name": "@g14o/ratelimit-nextjs",
  "version": "0.1.0",
  "description": "Next.js rate limiting with Upstash Redis — NextRequest/NextResponse types over @g14o/ratelimit.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/ratelimit/nextjs"
  },
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o/tree/main/packages/ratelimit/nextjs#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@g14o/ratelimit": "workspace:*"
  },
  "peerDependencies": {
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.0",
    "next": ">=15"
  },
  "peerDependenciesMeta": {
    "@upstash/ratelimit": {
      "optional": true
    },
    "@upstash/redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.0",
    "@workspace/typescript-config": "workspace:*",
    "dotenv": "^16.6.1",
    "next": "16.2.6",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rate-limit",
    "upstash",
    "redis",
    "nextjs",
    "next"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
