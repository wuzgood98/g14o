{
  "name": "@g14o/env-core",
  "version": "0.1.2",
  "description": "Framework-agnostic, typesafe environment variables via Standard Schema (Zod, Valibot, ArkType).",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/env-core"
  },
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o/tree/main/packages/env-core#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test-types/tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "arktype": "^2.0.0",
    "typescript": ">=5.0.0",
    "valibot": "^1.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "arktype": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@workspace/typescript-config": "workspace:*",
    "arktype": "^2.0.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.1",
    "typescript": "^5",
    "valibot": "^1.0.0",
    "vitest": "^3.2.4",
    "zod": "^4.0.0"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "environment",
    "env",
    "validation",
    "zod",
    "valibot",
    "arktype",
    "standard-schema",
    "typescript"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
