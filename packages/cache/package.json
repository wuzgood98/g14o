{
  "name": "@g14o/cache",
  "version": "0.5.0",
  "description": "Deprecated shim — use @g14o/core/cache instead.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@g14o/core": "workspace:^0.5.0"
  },
  "peerDependencies": {
    "next": ">=15"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@workspace/typescript-config": "workspace:*",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.1",
    "typescript": "^5"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "nextjs",
    "cache",
    "redis",
    "upstash"
  ],
  "engines": {
    "node": ">=20"
  }
}
