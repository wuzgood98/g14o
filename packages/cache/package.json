{
  "name": "@g14o/cache",
  "version": "0.1.1",
  "description": "Framework-agnostic Redis-backed caching with in-memory dev/build fallbacks.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git",
    "directory": "packages/cache"
  },
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://docs.g14o.dev/packages/cache",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "prepack": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "peerDependencies": {
    "@upstash/redis": "^1.34.0"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@upstash/redis": "^1.34.0",
    "@workspace/typescript-config": "workspace:*",
    "dotenv": "^16.6.1",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./config": {
      "dev-source": "./src/config.ts",
      "types": "./dist/config.d.mts",
      "default": "./dist/config.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "config": [
        "./dist/config.d.mts"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cache",
    "redis",
    "upstash"
  ],
  "engines": {
    "node": ">=22.18"
  }
}
