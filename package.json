{
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "turbo": "^2.9.15",
    "typescript": "^5",
    "ultracite": "7.8.0"
  },
  "name": "g14o",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git"
  },
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://docs.g14o.dev",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "test:dist": "node scripts/smoke-dist.mjs",
    "demo:cache": "pnpm --filter cache-demo dev",
    "demo:cache:build": "pnpm --filter cache-demo build",
    "demo:env": "pnpm --filter env-demo dev",
    "demo:env:build": "pnpm --filter env-demo build",
    "demo:paystack": "pnpm --filter paystack-demo dev",
    "demo:paystack:build": "pnpm --filter paystack-demo build",
    "demo:express": "pnpm --filter express-demo dev",
    "demo:express:start": "pnpm --filter express-demo start",
    "demo:hono": "pnpm --filter hono-demo dev",
    "demo:hono:start": "pnpm --filter hono-demo start",
    "docs": "pnpm --filter docs dev",
    "docs:dev": "pnpm run --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install",
    "release:publish:env": "pnpm --filter @g14o/env-core publish --access public --no-git-checks",
    "release:publish:cache": "pnpm --filter @g14o/cache publish --access public --no-git-checks",
    "release:publish:ratelimit": "pnpm --filter @g14o/ratelimit publish --access public --no-git-checks",
    "release:publish:ratelimit-nextjs": "pnpm --filter @g14o/ratelimit-nextjs publish --access public --no-git-checks",
    "release:publish:ratelimit-express": "pnpm --filter @g14o/ratelimit-express publish --access public --no-git-checks",
    "release:publish:ratelimit-hono": "pnpm --filter @g14o/ratelimit-hono publish --access public --no-git-checks",
    "release:publish:paystack": "pnpm --filter @g14o/paystack publish --access public --no-git-checks",
    "release:publish:paystack-better-auth": "pnpm --filter @g14o/paystack-better-auth publish --access public --no-git-checks",
    "commitlint": "commitlint --edit",
    "prepare": "husky"
  },
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "ultracite fix"
    ]
  }
}
