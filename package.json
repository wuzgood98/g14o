{
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "@workspace/typescript-config": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "turbo": "^2.9.15",
    "typescript": "^5",
    "ultracite": "7.8.0"
  },
  "name": "g14o",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzgood98/g14o.git"
  },
  "bugs": "https://github.com/wuzgood98/g14o/issues",
  "homepage": "https://github.com/wuzgood98/g14o#readme",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:integration": "turbo test:integration",
    "test:dist": "node scripts/smoke-dist.mjs",
    "demo:cache": "pnpm --filter cache-demo dev",
    "demo:cache:build": "pnpm --filter cache-demo build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:publish": "pnpm --filter @g14o/core publish --access public --no-git-checks",
    "prepare": "husky"
  },
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "ultracite fix"
    ]
  }
}
